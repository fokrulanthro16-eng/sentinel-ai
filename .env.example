# ─── AI ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Backend ─────────────────────────────────────────────────────────────────
# Leave DATABASE_URL empty to use the in-memory mock store (FastAPI)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sentinel_ai
SECRET_KEY=change-me-to-a-long-random-secret-32-chars-min
CORS_ORIGINS=http://localhost:3000

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAP_CENTER_LAT=-1.2921
NEXT_PUBLIC_MAP_CENTER_LNG=36.8219
NEXT_PUBLIC_MAP_ZOOM=12

# ─── NextAuth (required for login/register) ───────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-secret-for-nextauth
NEXTAUTH_URL=http://localhost:3000

# ─── Prisma (uses same PostgreSQL, sync driver — note: no +asyncpg) ───────────
# This overrides DATABASE_URL for the frontend/Prisma only
# DATABASE_URL=postgresql://user:password@localhost:5432/sentinel_ai
