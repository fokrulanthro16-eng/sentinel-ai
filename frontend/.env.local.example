# ── Sentinel AI Frontend — Environment Variables ─────────────────────────────
# For LOCAL DEVELOPMENT: copy to .env.local and fill in values.
# For VERCEL PRODUCTION:  set each variable in Vercel Dashboard → Settings → Environment Variables.
#
# ⚠  NEXT_PUBLIC_* variables are baked into the JS bundle at BUILD TIME.
#    After setting or changing them you MUST redeploy the Vercel project.

# ── Backend API ───────────────────────────────────────────────────────────────
# The Render service URL.  No trailing slash.
# Vercel: set to https://<your-service>.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Map defaults (Nairobi)
NEXT_PUBLIC_MAP_CENTER_LAT=-1.2921
NEXT_PUBLIC_MAP_CENTER_LNG=36.8219
NEXT_PUBLIC_MAP_ZOOM=12

# ── NextAuth ──────────────────────────────────────────────────────────────────
# NEXTAUTH_URL  – The canonical URL of this Next.js deployment.
#   Local:   http://localhost:3000
#   Vercel:  https://<your-app>.vercel.app
#            (Vercel sets VERCEL_URL automatically; NextAuth can detect it
#             automatically on Vercel, but setting it explicitly is safer.)
NEXTAUTH_URL=http://localhost:3000

# NEXTAUTH_SECRET – Random string used to sign NextAuth session JWTs (cookies).
#   Does NOT need to equal SECRET_KEY on Render.
#   FastAPI issues its own Bearer token at login; NextAuth carries it through as-is.
#
# Generate:
#   openssl rand -base64 32
# Set in:
#   Vercel → Settings → Environment Variables → NEXTAUTH_SECRET
NEXTAUTH_SECRET=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# ── Database (Prisma) ─────────────────────────────────────────────────────────
# PostgreSQL connection string for NextAuth user storage.
# Vercel:  set to your Neon / Supabase / Railway connection string.
# Local:   uncomment and fill in your local PostgreSQL details.
# DATABASE_URL=postgresql://sentinel:sentinel_pass@localhost:5432/sentinel_ai
