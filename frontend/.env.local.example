# ── Sentinel AI Frontend — Environment Variables ─────────────────────────────
# Copy this file to .env.local and fill in real values.

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Map defaults (Nairobi)
NEXT_PUBLIC_MAP_CENTER_LAT=-1.2921
NEXT_PUBLIC_MAP_CENTER_LNG=36.8219
NEXT_PUBLIC_MAP_ZOOM=12

# WebSocket (optional — auto-derived from NEXT_PUBLIC_API_URL if not set)
# NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
# IMPORTANT: NEXTAUTH_SECRET must be the same value as SECRET_KEY in the backend .env
#            The frontend uses it to sign JWTs that the backend validates as Bearer tokens.
NEXTAUTH_SECRET=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET_AT_LEAST_32_CHARS
