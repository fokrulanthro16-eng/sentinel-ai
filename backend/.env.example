# ── Sentinel AI Backend — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in real values before running in production.

# App
APP_NAME="Sentinel AI: Community ActionGrid"
APP_VERSION=1.0.0
DEBUG=false

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
# IMPORTANT: This value MUST match NEXTAUTH_SECRET in the frontend .env.local
#            so that NextAuth JWTs are accepted as Bearer tokens by the backend.
SECRET_KEY=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS

# AI (optional — app runs in demo mode without it)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Database (leave empty to use in-memory mock store)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Redis (optional — leave empty for single-instance in-memory WebSocket mode)
# Required for multi-instance/multi-worker deployments to share WebSocket broadcast
# and rate-limit counters across pods.
# Format: redis://user:password@host:6379/0
REDIS_URL=

# External Intelligence (all optional — fallback to mock data)
OPENWEATHER_API_KEY=
NASA_FIRMS_API_KEY=

# SMS Gateway (leave blank → mock/log mode)
SMS_GATEWAY_URL=
SMS_API_KEY=

# Email SMTP (leave blank → mock/log mode)
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=alerts@sentinel-ai.ke

# WhatsApp Cloud API (leave blank → mock/log mode)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000
